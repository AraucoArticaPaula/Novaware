<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!--
    Modal: Agregar / Editar Producto
    Se abre como Stage secundario desde InventarioController.
    Al guardar, el controller recarga la tabla automáticamente.
    El mismo FXML sirve para AGREGAR (campos vacíos) y EDITAR (campos prellenados).
-->
<VBox xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.novaware.controllers.AgregarProductoController"
      prefWidth="500" prefHeight="620"
      spacing="10"
      style="-fx-background-color: white; -fx-padding: 25;">

   <!-- Título dinámico: cambia entre "Agregar producto" y "Editar producto" desde el controller -->
   <Label fx:id="lblTitulo" text="Agregar producto"
          style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;">
      <font><Font name="System Bold" size="20.0" /></font>
   </Label>
   <Label fx:id="lblSubtitulo" text="Completa los datos del nuevo producto"
          style="-fx-font-size: 12; -fx-text-fill: #888888;" />
   <Separator />

   <!-- ===== GRID DE CAMPOS ===== -->
   <GridPane hgap="12" vgap="10" VBox.vgrow="NEVER">
      <columnConstraints>
         <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
         <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
      </columnConstraints>

      <!-- Fila 0: Código de producto | Categoría -->
      <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
         <Label text="Código de producto *"
                style="-fx-font-size: 11; -fx-text-fill: #555; -fx-font-weight: bold;" />
         <TextField fx:id="txtCodigo"
                    promptText="Ej: PROD-001"
                    style="-fx-background-radius: 8; -fx-border-radius: 8;
                           -fx-border-color: #cccccc; -fx-padding: 7 10; -fx-font-size: 13;" />
      </VBox>
      <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
         <Label text="Categoría *"
                style="-fx-font-size: 11; -fx-text-fill: #555; -fx-font-weight: bold;" />
         <ComboBox fx:id="comboCategoria"
                   promptText="Selecciona"
                   maxWidth="Infinity"
                   style="-fx-background-radius: 8; -fx-font-size: 13;" />
      </VBox>

      <!-- Fila 1: Nombre del producto (ocupa 2 columnas) -->
      <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1"
            GridPane.columnSpan="2">
         <Label text="Nombre del producto *"
                style="-fx-font-size: 11; -fx-text-fill: #555; -fx-font-weight: bold;" />
         <TextField fx:id="txtNombre"
                    promptText="Ej: Televisor Samsung 55 pulgadas"
                    style="-fx-background-radius: 8; -fx-border-radius: 8;
                           -fx-border-color: #cccccc; -fx-padding: 7 10; -fx-font-size: 13;" />
      </VBox>

      <!-- Fila 2: Marca | Modelo -->
      <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="2">
         <Label text="Marca"
                style="-fx-font-size: 11; -fx-text-fill: #555; -fx-font-weight: bold;" />
         <TextField fx:id="txtMarca"
                    promptText="Ej: Samsung"
                    style="-fx-background-radius: 8; -fx-border-radius: 8;
                           -fx-border-color: #cccccc; -fx-padding: 7 10; -fx-font-size: 13;" />
      </VBox>
      <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="2">
         <Label text="Modelo"
                style="-fx-font-size: 11; -fx-text-fill: #555; -fx-font-weight: bold;" />
         <TextField fx:id="txtModelo"
                    promptText="Ej: UN55TU7000"
                    style="-fx-background-radius: 8; -fx-border-radius: 8;
                           -fx-border-color: #cccccc; -fx-padding: 7 10; -fx-font-size: 13;" />
      </VBox>

      <!-- Fila 3: Precio venta | Precio compra -->
      <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="3">
         <Label text="Precio venta (S/) *"
                style="-fx-font-size: 11; -fx-text-fill: #555; -fx-font-weight: bold;" />
         <TextField fx:id="txtPrecioVenta"
                    promptText="Ej: 1999.90"
                    style="-fx-background-radius: 8; -fx-border-radius: 8;
                           -fx-border-color: #cccccc; -fx-padding: 7 10; -fx-font-size: 13;" />
      </VBox>
      <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="3">
         <Label text="Precio compra (S/)"
                style="-fx-font-size: 11; -fx-text-fill: #555; -fx-font-weight: bold;" />
         <TextField fx:id="txtPrecioCompra"
                    promptText="Ej: 1500.00"
                    style="-fx-background-radius: 8; -fx-border-radius: 8;
                           -fx-border-color: #cccccc; -fx-padding: 7 10; -fx-font-size: 13;" />
      </VBox>

      <!-- Fila 4: Stock actual | Stock mínimo -->
      <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="4">
         <Label text="Stock actual *"
                style="-fx-font-size: 11; -fx-text-fill: #555; -fx-font-weight: bold;" />
         <TextField fx:id="txtStock"
                    promptText="Ej: 10"
                    style="-fx-background-radius: 8; -fx-border-radius: 8;
                           -fx-border-color: #cccccc; -fx-padding: 7 10; -fx-font-size: 13;" />
      </VBox>
      <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="4">
         <Label text="Stock mínimo (alerta)"
                style="-fx-font-size: 11; -fx-text-fill: #555; -fx-font-weight: bold;" />
         <TextField fx:id="txtStockMin"
                    promptText="Ej: 3"
                    style="-fx-background-radius: 8; -fx-border-radius: 8;
                           -fx-border-color: #cccccc; -fx-padding: 7 10; -fx-font-size: 13;" />
      </VBox>

      <!-- Fila 5: Fecha ingreso stock | Vendedor que hizo inventario -->
      <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="5">
         <Label text="Fecha ingreso de stock *"
                style="-fx-font-size: 11; -fx-text-fill: #555; -fx-font-weight: bold;" />
         <DatePicker fx:id="dpFechaIngreso"
                     promptText="dd/mm/aaaa"
                     maxWidth="Infinity"
                     style="-fx-background-radius: 8; -fx-font-size: 13;" />
      </VBox>
      <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="5">
         <Label text="Vendedor responsable"
                style="-fx-font-size: 11; -fx-text-fill: #555; -fx-font-weight: bold;" />
         <!-- Se llena dinámicamente con los vendedores de la BD -->
         <ComboBox fx:id="comboVendedor"
                   promptText="Selecciona vendedor"
                   maxWidth="Infinity"
                   style="-fx-background-radius: 8; -fx-font-size: 13;" />
      </VBox>

      <!-- Fila 6: Código vendedor (solo lectura, se autocompleta al elegir vendedor) -->
      <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="6">
         <Label text="Código del vendedor"
                style="-fx-font-size: 11; -fx-text-fill: #555; -fx-font-weight: bold;" />
         <TextField fx:id="txtCodigoVendedor"
                    promptText="Se autocompleta"
                    editable="false"
                    style="-fx-background-radius: 8; -fx-border-radius: 8;
                           -fx-border-color: #eeeeee; -fx-padding: 7 10; -fx-font-size: 13;
                           -fx-background-color: #f5f5f5; -fx-text-fill: #888888;" />
      </VBox>
      <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="6">
         <Label text="Proveedor"
                style="-fx-font-size: 11; -fx-text-fill: #555; -fx-font-weight: bold;" />
         <TextField fx:id="txtProveedor"
                    promptText="Ej: Importaciones XYZ"
                    style="-fx-background-radius: 8; -fx-border-radius: 8;
                           -fx-border-color: #cccccc; -fx-padding: 7 10; -fx-font-size: 13;" />
      </VBox>

   </GridPane>

   <!-- Mensaje de error -->
   <Label fx:id="lblError"
          text=""
          style="-fx-text-fill: #A32D2D; -fx-font-size: 12;"
          visible="false"
          managed="false" />

   <VBox VBox.vgrow="ALWAYS" />

   <!-- Nota campos obligatorios -->
   <Label text="* Campos obligatorios"
          style="-fx-font-size: 11; -fx-text-fill: #aaaaaa;" />

   <!-- Botones -->
   <HBox spacing="10">
      <Button text="Cancelar"
              onAction="#cancelar"
              style="-fx-background-color: transparent; -fx-border-color: #cccccc;
                     -fx-border-radius: 8; -fx-background-radius: 8;
                     -fx-font-size: 13; -fx-padding: 9 20; -fx-cursor: hand;"
              HBox.hgrow="ALWAYS" maxWidth="Infinity" />
      <Button fx:id="btnGuardar"
              text="Guardar producto"
              onAction="#guardar"
              style="-fx-background-color: #185FA5; -fx-text-fill: white;
                     -fx-border-radius: 8; -fx-background-radius: 8;
                     -fx-font-size: 13; -fx-font-weight: bold;
                     -fx-padding: 9 20; -fx-cursor: hand;"
              HBox.hgrow="ALWAYS" maxWidth="Infinity" />
   </HBox>

</VBox>
