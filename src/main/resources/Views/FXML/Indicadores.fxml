                        <Label text="INDICADORES DE TIENDA" style="-fx-text-fill: black;">
                           <font>
                              <Font name="System Bold" size="31.0" />
                           </font>
                        </Label>
                        <Region HBox.hgrow="ALWAYS" />
                        <MenuButton fx:id="menuPeriodo" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" prefHeight="31.0" prefWidth="169.0" style="-fx-background-color: black; -fx-background-radius: 15;" text="Periodo" textFill="WHITE">
