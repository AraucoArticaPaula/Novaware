            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="270.0">
               <children>
                  <ImageView fitHeight="32.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../Imagenes/factura.png" />
