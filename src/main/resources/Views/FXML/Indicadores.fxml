                                    </Label>
                                    <Label fx:id="lblPorcentajeMeta" text="0.00%" textFill="WHITE">
                                       <font>
                                          <Font size="34.0" />
                                       </font>
                                    </Label>
                                    <Label text="de la meta alcanzada" textFill="#888888">
                                       <font>
                                          <Font size="12.0" />
                                       </font>
                                    </Label>
                                 </children>
                              </VBox>
                           </children>
