                                    </Label>
                                    <Label fx:id="lblMontoVendido" text="S/0.00" textFill="WHITE">
                                       <font>
                                          <Font size="34.0" />
                                       </font>
                                    </Label>
                                    <Label text="en el periodo" textFill="#888888">
                                       <font>
                                          <Font size="12.0" />
                                       </font>
                                    </Label>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        <HBox prefHeight="140.0" style="-fx-background-color: black; -fx-background-radius: 20;" HBox.hgrow="ALWAYS">
                           <children>
                              <VBox spacing="4.0">
                                 <padding>
                                    <Insets left="15.0" top="15.0" />
                                 </padding>
                                 <children>
                                    <Label text="Meta del mes" textFill="#d9d9d9">
                                       <font>
                                          <Font name="Inter 24pt Regular" size="14.0" />
                                       </font>
                                    </Label>
                                    <Label fx:id="lblMetaMes" text="S/0.00" textFill="WHITE">
                                       <font>
                                          <Font size="34.0" />
                                       </font>
                                    </Label>
                                    <Label text="objetivo mensual" textFill="#888888">
                                       <font>
                                          <Font size="12.0" />
                                       </font>
                                    </Label>
