                        <DatePicker fx:id="dpFecha" prefHeight="27.0" prefWidth="200.0" style="-fx-border-color: black;" />
                     </children>
                  </HBox>

                  <!-- Fila 1 de tarjetas -->
                  <HBox prefHeight="140.0" prefWidth="980.0" spacing="10.0">
